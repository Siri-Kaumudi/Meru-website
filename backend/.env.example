# MongoDB — use localhost:27015 when connecting from the VPS host (mongosh, backups).
# The Docker backend container overrides this with mongodb://mongodb:27017/meru-website.
MONGO_URI=mongodb://localhost:27015/meru-website
# API port (proxied by Nginx, not exposed publicly)
PORT=5500

# Your live domain (used for CORS)
CLIENT_URL=https://merucorporation.in

# Generate a strong secret: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password
